{
	"name": "detain/myadmin-softaculous-licensing",
	"type": "myadmin-plugin",
	"description": "Softaculous Licensing Class",
	"keywords": [
		"softaculous",
		"administration",
		"license"
	],
	"license": "LGPL-2.1-only",
	"authors": [
		{
			"name": "Joe Huss",
			"homepage": "https:\/\/my.interserver.net\/"
		}
	],
	"config": {
		"bin-dir": "vendor\/bin",
		"minimum-stability": "dev",
		"allow-plugins": {
			"detain/myadmin-plugin-installer": true
		}
	},
	"require": {
		"php": ">=8.2",
		"ext-soap": "*",
		"detain/myadmin-plugin-installer": "dev-master",
		"symfony/event-dispatcher": "^5.0|^6.0|^7.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"autoload": {
		"psr-4": {
			"Detain\\MyAdminSoftaculous\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Detain\\MyAdminSoftaculous\\Tests\\": "tests/"
		}
	}
}
